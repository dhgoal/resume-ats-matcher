{
  "name": "resume-ats-matcher",
  "version": "1.0.0",
  "description": "Rank DOCX resumes against a job description with ATS scoring, powered by Chutes.ai LLMs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "electron scripts/generate-icon.cjs",
    "dist": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "docx": "^9.7.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "png-to-ico": "^3.0.2"
  },
  "build": {
    "appId": "com.jct.resumeatsmatcher",
    "productName": "Resume ATS Matcher",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icon.ico",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    }
  }
}
